# SMTP configuration for Gmail (example)
# For Gmail: enable "App Passwords" in your Google Account settings
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email address that will receive contact form messages
CONTACT_EMAIL=contact@risinghopeglobal.org
PORT=5000

# Set to 'true' to enable mock mode (test without real email sending)
MOCK_EMAIL=true
